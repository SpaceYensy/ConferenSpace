@page "/calendario"

<PageTitle>Calendario de Reservas - ConferenSpace</PageTitle>

<h2><i class="bi bi-calendar-week text-info"></i> Calendario de Disponibilidad</h2>
<hr />

<div class="row mb-4">
    <div class="col-md-3">
        <label class="form-label">Salón</label>
        <select class="form-select" @bind="salonSeleccionadoId" @bind:after="CargarReservas">
            <option value="0">Todos los salones</option>
            @foreach (var s in salones)
            {
                <option value="@s.Id">@s.Nombre (@s.Ubicacion)</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label">Semana del</label>
        <input type="date" class="form-control" @bind="fechaInicioSemana" @bind:after="CargarReservas" />
    </div>
    <div class="col-md-3 d-flex align-items-end">
        <button class="btn btn-outline-primary me-2" @onclick="SemanaAnterior">
            <i class="bi bi-chevron-left"></i> Anterior
        </button>
        <button class="btn btn-outline-primary" @onclick="SemanaSiguiente">
            Siguiente <i class="bi bi-chevron-right"></i>
        </button>
    </div>
    <div class="col-md-3 d-flex align-items-end">
        <button class="btn btn-outline-secondary" @onclick="IrAHoy">Hoy</button>
    </div>
</div>

@if (cargando)
{
    <div class="text-center my-5"><div class="spinner-border text-info"></div></div>
}
else
{
    <div class="table-responsive shadow rounded">
        <table class="table table-bordered mb-0">
            <thead class="table-dark text-center">
                <tr>
                    <th style="width: 150px;">Salón / Hora</th>
                    @foreach (var dia in diasSemana)
                    {
                        <th class="@(dia.Date == DateTime.Today ? "bg-primary" : "")">
                            @dia.ToString("ddd")<br />@dia.ToString("dd/MM")
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @{
                    var salonesMostrar = salonSeleccionadoId == 0 ? salones.Where(s => s.EstaActivo).ToList() : salones.Where(s => s.Id == salonSeleccionadoId).ToList();
                }

                @foreach (var salon in salonesMostrar)
                {
                    <tr>
                        <td class="fw-bold align-middle">
                            @salon.Nombre<br />
                            <small class="text-muted">Cap: @salon.CapacidadMaxima</small>
                        </td>
                        @foreach (var dia in diasSemana)
                        {
                            var reservasDia = reservas
                                .Where(r => r.SalonId == salon.Id && r.Fecha.Date == dia.Date)
                                .OrderBy(r => r.HoraInicio)
                                .ToList();

                            <td class="p-1 align-top" style="min-height: 80px;">
                                @if (reservasDia.Any())
                                {
                                    @foreach (var res in reservasDia)
                                    {
                                        var altura = (res.HoraFin - res.HoraInicio).TotalHours * 40;
                                        <div class="badge w-100 mb-1 p-1 text-start
                                            @(res.Estado == "Cancelada" ? "bg-danger" : "bg-success")"
                                             style="min-height: @(altura)px; font-size: 0.7rem;">
                                            @res.HoraInicio.ToString(@"hh\:mm")-@res.HoraFin.ToString(@"hh\:mm")
                                            <br />@(res.Solicitante?.NombreCompleto?.Split(' ').FirstOrDefault() ?? "N/A")
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted" style="font-size: 0.7rem;">Disponible</span>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        <span class="badge bg-success me-2">&nbsp;</span> Confirmada
        <span class="badge bg-danger">&nbsp;</span> Cancelada
    </div>
}

@code {
    private List<Salon> salones = new();
    private List<Reserva> reservas = new();
    private int salonSeleccionadoId;
    private DateTime fechaInicioSemana;
    private bool cargando = true;

    private List<DateTime> diasSemana => Enumerable.Range(0, 7)
        .Select(d => fechaInicioSemana.AddDays(d))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        fechaInicioSemana = ObtenerInicioSemana(DateTime.Today);
        try { salones = await Api.GetSalonesAsync(); } catch { }
        await CargarReservas();
    }

    private DateTime ObtenerInicioSemana(DateTime fecha)
    {
        int diff = (7 + (fecha.DayOfWeek - DayOfWeek.Monday)) % 7;
        return fecha.AddDays(-diff).Date;
    }

    private async Task CargarReservas()
    {
        cargando = true;
        try
        {
            var todas = await Api.GetReservasAsync();
            reservas = todas.Where(r =>
                r.Fecha >= fechaInicioSemana && r.Fecha <= fechaInicioSemana.AddDays(6)).ToList();
        }
        catch { }
        cargando = false;
    }

    private async Task SemanaAnterior()
    {
        fechaInicioSemana = fechaInicioSemana.AddDays(-7);
        await CargarReservas();
    }

    private async Task SemanaSiguiente()
    {
        fechaInicioSemana = fechaInicioSemana.AddDays(7);
        await CargarReservas();
    }

    private async Task IrAHoy()
    {
        fechaInicioSemana = ObtenerInicioSemana(DateTime.Today);
        await CargarReservas();
    }
}