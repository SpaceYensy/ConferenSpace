@page "/salones"

<PageTitle>Gestión de Salones - ConferenSpace</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-door-open me-2" style="color: var(--accent-purple);"></i> <span style="color: var(--accent-purple);">Gestión de Salones</span></h2>
    <button class="btn btn-primary" @onclick="AbrirFormularioCrear">
        <i class="bi bi-plus-lg"></i> Nuevo Salón
    </button>
</div>

@if (mostrarFormulario)
{
    <div class="card mb-4 shadow">
        <div class="card-header @(editando ? "bg-warning" : "bg-success") text-white">
            <h5 class="mb-0">@(editando ? "Editar Salón" : "Nuevo Salón")</h5>
        </div>
        <div class="card-body">
            <EditForm Model="@formModel" OnValidSubmit="@GuardarSalon">
                <DataAnnotationsValidator />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Nombre</label>
                        <InputText @bind-Value="formModel.Nombre" class="form-control" placeholder="Ej: Sala Innovación" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Ubicación</label>
                        <InputText @bind-Value="formModel.Ubicacion" class="form-control" placeholder="Ej: Piso 3, Edificio A" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Capacidad Máxima</label>
                        <InputNumber @bind-Value="formModel.CapacidadMaxima" class="form-control" min="1" />
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Servicios Integrados</label>
                        <InputText @bind-Value="formModel.ServiciosIntegrados" class="form-control" placeholder="Ej: Proyector, Videoconferencia" />
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn @(editando ? "btn-warning" : "btn-success")">
                        <i class="bi bi-check-lg"></i> @(editando ? "Actualizar" : "Guardar")
                    </button>
                    <button type="button" class="btn btn-secondary ms-2" @onclick="CerrarFormulario">Cancelar</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (cargando)
{
    <div class="text-center my-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else if (!salones.Any())
{
    <div class="alert alert-info text-center">
        <i class="bi bi-info-circle"></i> No hay salones registrados. ¡Crea el primero!
    </div>
}
else
{
    <div class="row">
        @foreach (var s in salones)
        {
            <div class="col-md-6 col-lg-4 mb-3">
                <div class="card shadow-sm h-100 @(s.EstaActivo ? "" : "border-danger bg-light")">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="bi bi-door-open-fill text-primary"></i> @s.Nombre
                            @if (!s.EstaActivo)
                            {
                                <span class="badge bg-danger">Fuera de Servicio</span>
                            }
                        </h5>
                        <p class="card-text mb-1"><i class="bi bi-geo-alt"></i> @s.Ubicacion</p>
                        <p class="card-text mb-1"><i class="bi bi-people"></i> Capacidad: @s.CapacidadMaxima personas</p>
                        <p class="card-text"><i class="bi bi-tools"></i> @(string.IsNullOrEmpty(s.ServiciosIntegrados) ? "Sin servicios" : s.ServiciosIntegrados)</p>
                        <div class="btn-group">
                            <button class="btn btn-sm btn-outline-warning" @onclick="() => AbrirFormularioEditar(s)">
                                <i class="bi bi-pencil"></i> Editar
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarSalon(s.Id)">
                                <i class="bi bi-trash"></i> Eliminar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Salon> salones = new();
    private Salon formModel = new();
    private bool mostrarFormulario;
    private bool editando;
    private bool cargando = true;

    protected override async Task OnInitializedAsync()
    {
        await CargarSalones();
    }

    private async Task CargarSalones()
    {
        cargando = true;
        try
        {
            salones = await Api.GetSalonesAsync();
        }
        catch { }
        cargando = false;
    }

    private void AbrirFormularioCrear()
    {
        formModel = new Salon { EstaActivo = true };
        editando = false;
        mostrarFormulario = true;
    }

    private void AbrirFormularioEditar(Salon s)
    {
        formModel = new Salon
        {
            Id = s.Id,
            Nombre = s.Nombre,
            Ubicacion = s.Ubicacion,
            CapacidadMaxima = s.CapacidadMaxima,
            ServiciosIntegrados = s.ServiciosIntegrados,
            EstaActivo = s.EstaActivo
        };
        editando = true;
        mostrarFormulario = true;
    }

    private async Task GuardarSalon()
    {
        try
        {
            if (editando)
                await Api.UpdateSalonAsync(formModel.Id, formModel);
            else
                await Api.CreateSalonAsync(formModel);

            mostrarFormulario = false;
            await CargarSalones();
        }
        catch { }
    }

    private void CerrarFormulario() => mostrarFormulario = false;

    private async Task EliminarSalon(int id)
    {
        try
        {
            await Api.DeleteSalonAsync(id);
            await CargarSalones();
        }
        catch { }
    }
}